<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG Chatbot & Research Platform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="navbar-brand navbar-brand-custom text-gradient" asp-area="" asp-controller="Course" asp-action="Index">
                        <i class="bi bi-stars"></i>
                        RAG RESEARCH
                    </a>
                }
                else
                {
                    <a class="navbar-brand navbar-brand-custom text-gradient" asp-area="" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-stars"></i>
                        RAG RESEARCH
                    </a>
                }
                <button class="navbar-toggler border-0 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="fs-4">☰</span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Course" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                   asp-area="" asp-controller="Course" asp-action="Index">
                                    <i class="bi bi-book-half me-2"></i>Khóa học &amp; Tài liệu
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                                   asp-controller="Admin" asp-action="Users">
                                    <i class="bi bi-people-fill me-2"></i>Quản lý Users
                                </a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Course" && ViewContext.RouteData.Values["action"]?.ToString() == "Search" ? "active" : "")" 
                                       asp-controller="Course" asp-action="Search" title="Tìm lớp học">
                                        <i class="bi bi-search me-2"></i>Tìm lớp
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav ms-lg-3 align-items-lg-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <a asp-controller="Account" asp-action="Profile" class="badge bg-light text-dark border px-3 py-2 rounded-pill fs-7 d-inline-flex align-items-center gap-2 text-decoration-none" style="transition: all 0.2s; cursor: pointer;" title="Xem hồ sơ & Đổi mật khẩu">
                                    <i class="bi bi-person-fill text-primary"></i>
                                    @(User.FindFirst("FullName")?.Value ?? User.Identity.Name)
                                </a>
                            </li>
                            <li class="nav-item">
                                <!-- CSRF Protection: Logout uses POST and a hidden antiforgery token -->
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0 p-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 py-2 d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-premium btn-sm rounded-pill px-4 py-2 d-inline-flex align-items-center gap-1" href="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto">
        <div class="container text-center">
            &copy; 2026 - RAG Chatbot System & Research Platform - Built with .NET 10
        </div>
    </footer>

    <!-- Toast Notification Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 9999;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div id="successToast" class="toast toast-success-custom align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2 py-3">
                        <div class="fw-semibold">@TempData["SuccessMessage"]</div>
                    </div>
                    <button type="button" class="btn-close me-3 m-auto" data-bs-dismiss="toast" aria-label="Close" style="filter: invert(34%) sepia(85%) saturate(362%) hue-rotate(113deg) brightness(91%) contrast(92%);"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div id="errorToast" class="toast toast-error-custom align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2 py-3">
                        <div class="fw-semibold">@TempData["ErrorMessage"]</div>
                    </div>
                    <button type="button" class="btn-close me-3 m-auto" data-bs-dismiss="toast" aria-label="Close" style="filter: invert(18%) sepia(91%) saturate(2206%) hue-rotate(334deg) brightness(84%) contrast(93%);"></button>
                </div>
            </div>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            var toastList = toastElList.map(function (toastEl) {
                return new bootstrap.Toast(toastEl, { autohide: true, delay: 4000 });
            });
            toastList.forEach(toast => toast.show());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
