@model IEnumerable<RagChatBox.DAL.Entities.Document>
@using System.Security.Claims
@{
    var course = ViewBag.Course as RagChatBox.DAL.Entities.Course;
    ViewData["Title"] = $"Tài liệu - {course?.Name}";

    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = int.TryParse(userIdClaim, out var parsedId) ? parsedId : (int?)null;
    var canManageDocuments = (User.IsInRole("admin") || User.IsInRole("teacher")) && (User.IsInRole("admin") || (course != null && course.CreatedBy == currentUserId));
}

<div class="page-container m-0 p-0">
    <!-- Navigation / Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-controller="Course" asp-action="Index" class="text-muted-custom nav-link-custom p-1 d-inline-flex align-items-center justify-content-center" style="background: none; border-radius: 50%; text-decoration: none;" title="Quay lại danh sách khóa học">
                    <i class="bi bi-arrow-left-circle fs-4"></i>
                </a>
                <h1 class="h2 mb-0"><i class="bi bi-folder2-open text-gradient me-2"></i>Tài liệu học tập</h1>
            </div>
            <p class="text-muted-custom ms-4 ps-2">Khóa học: <span class="text-dark fw-semibold">@course?.Name</span></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Chat" asp-action="Index" asp-route-courseId="@course?.Id" class="btn btn-outline-primary d-inline-flex align-items-center gap-2 rounded-pill py-2 px-4 shadow-sm fw-semibold" style="border: 2px solid rgba(79, 70, 229, 0.5); color: #4f46e5; transition: all 0.2s;">
                <i class="bi bi-stars"></i> Hỏi đáp AI (RAG)
            </a>
            @if (canManageDocuments)
            {
                <a asp-action="Upload" asp-route-courseId="@course?.Id" class="btn-premium d-inline-flex align-items-center gap-2" style="text-decoration: none;">
                    <i class="bi bi-cloud-arrow-up"></i>
                    Tải lên tài liệu
                </a>
            }
        </div>
    </div>

    <!-- Document List Panel -->
    <div class="glass-panel">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="icon-badge mx-auto mb-3"><i class="bi bi-file-earmark-arrow-up"></i></div>
                <h3 class="h5">Chưa có tài liệu nào được tải lên</h3>
                <p class="text-muted-custom mb-4">
                    @(canManageDocuments ? "Hãy tải tài liệu môn học đầu tiên của bạn để làm giàu kho tri thức RAG." : "Liên hệ quản trị viên hoặc người tạo khóa học để cập nhật thêm tài liệu cho khóa học này.")
                </p>
                @if (canManageDocuments)
                {
                    <a asp-action="Upload" asp-route-courseId="@course?.Id" class="btn-premium d-inline-flex align-items-center gap-2" style="text-decoration: none;">
                        <i class="bi bi-cloud-arrow-up"></i>
                        Tải lên ngay
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th><i class="bi bi-file-earmark-text me-2"></i>Tên tài liệu</th>
                            <th><i class="bi bi-file-earmark me-2"></i>Định dạng</th>
                            <th><i class="bi bi-hdd me-2"></i>Kích thước</th>
                            <th><i class="bi bi-activity me-2"></i>Trạng thái</th>
                            <th><i class="bi bi-person me-2"></i>Người tải</th>
                            <th><i class="bi bi-calendar3 me-2"></i>Ngày tải lên</th>
                            <th class="text-end"><i class="bi bi-sliders me-2"></i>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-medium">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="icon-badge-sm"><i class="bi bi-file-earmark-text"></i></span>
                                        <span class="text-truncate" style="max-width: 300px;" title="@item.FileName">@item.FileName</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.ErrorMessage))
                                    {
                                        <div class="text-rose text-sm mt-1" style="font-size: 0.8rem;">
                                            @item.ErrorMessage
                                        </div>
                                    }
                                </td>
                                <td><span class="text-uppercase text-muted fw-bold">@item.FileType.TrimStart('.')</span></td>
                                <td>
                                    @(item.FileSize < 1024 * 1024 
                                        ? $"{(double)item.FileSize / 1024:N1} KB" 
                                        : $"{(double)item.FileSize / (1024 * 1024):N1} MB")
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="status-badge status-pending">
                                            <span class="spinner-grow spinner-grow-sm text-warning" role="status" style="width: 8px; height: 8px;"></span>
                                            Chờ xử lý
                                        </span>
                                    }
                                    else if (item.Status == "Processing")
                                    {
                                        <span class="status-badge status-processing">
                                            <span class="spinner-border spinner-border-sm text-primary" role="status" style="width: 10px; height: 10px;"></span>
                                            Đang xử lý
                                        </span>
                                    }
                                    else if (item.Status == "Indexed")
                                    {
                                        <span class="status-badge status-indexed">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Đã chỉ mục
                                        </span>
                                    }
                                    else // Failed
                                    {
                                        <span class="status-badge status-failed">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                            Lỗi chỉ mục
                                        </span>
                                    }
                                </td>
                                <td class="text-muted-custom">@(string.IsNullOrEmpty(item.UploadedBy) ? "Hệ thống" : item.UploadedBy)</td>
                                <td class="text-muted-custom">@item.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        @if (item.Status == "Indexed" && (User.IsInRole("admin") || User.IsInRole("teacher")))
                                         {
                                         <a asp-action="Chunks" asp-route-documentId="@item.Id" class="btn-secondary-custom py-1.5 px-3 fs-7" style="background-color: rgba(79, 70, 229, 0.08); color: #4f46e5; border-color: rgba(79, 70, 229, 0.2);" title="Xem các phân đoạn chỉ mục RAG">
                                             <i class="bi bi-file-earmark-medical"></i>
                                             Phân đoạn
                                         </a>
                                         }
                                         <a asp-action="Download" asp-route-id="@item.Id" class="btn-secondary-custom py-1.5 px-3 fs-7" title="Xem tài liệu">
                                            <i class="bi bi-eye"></i>
                                            Xem
                                        </a>
                                        
                                        @if (canManageDocuments)
                                        {
                                        <form asp-action="Delete" asp-route-id="@item.Id" asp-route-courseId="@course?.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài liệu này không?');" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-danger-custom py-1.5 px-3 fs-7">
                                                <i class="bi bi-trash"></i>
                                                Xóa
                                            </button>
                                        </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
}
