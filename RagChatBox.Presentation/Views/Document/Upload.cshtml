@model RagChatBox.Presentation.Models.DocumentUploadViewModel
@{
    var course = ViewBag.Course as RagChatBox.DAL.Entities.Course;
    ViewData["Title"] = $"Tải lên tài liệu - {course?.Name}";
}

<div class="page-container m-0 p-0">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="glass-panel">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="text-muted-custom nav-link-custom p-1 d-inline-flex align-items-center justify-content-center" style="background: none; border-radius: 50%; text-decoration: none;" title="Quay lại">
                        <i class="bi bi-arrow-left-circle fs-4"></i>
                    </a>
                    <h2 class="h3 mb-0"><span class="text-gradient"><i class="bi bi-cloud-arrow-up me-2"></i>Tải lên học liệu</span></h2>
                </div>
                <p class="text-muted-custom mb-4 ms-4 ps-2">Khóa học: <strong class="text-dark">@course?.Name</strong></p>

                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CourseId" />

                    <div class="form-group-custom">
                        <label asp-for="File" class="form-label-custom"><i class="bi bi-paperclip me-2"></i>Tệp tài liệu</label>
                        
                        <!-- Drag & Drop Area styled in site.css -->
                        <div class="upload-drag-area" id="dragArea">
                            <span class="upload-icon"><i class="bi bi-cloud-arrow-up"></i></span>
                            <h4 class="h5 mb-2">Kéo thả tệp tin hoặc nhấp để duyệt</h4>
                            <p class="text-muted-custom text-sm mb-0">Hỗ trợ các định dạng PDF, DOCX (Tối đa 50MB)</p>
                            
                            <!-- Hidden input element -->
                            <input type="file" asp-for="File" class="d-none" id="fileInput" accept=".pdf,.docx" />
                        </div>
                        
                        <!-- Selected File Name indicator -->
                        <div class="d-none p-3 mb-3 border border-dashed border-primary border-opacity-20 rounded-3 text-center" id="fileSelectedContainer">
                            <div class="d-flex align-items-center justify-content-center gap-2 text-dark fw-semibold">
                                <span id="selectedFileName">filename.pdf</span>
                                <span class="text-muted" id="selectedFileSize" style="font-size: 0.85rem;">(0 MB)</span>
                                <button type="button" class="btn-close ms-2" id="clearFileBtn" aria-label="Xóa file"></button>
                            </div>
                        </div>

                        <span asp-validation-for="File" class="validation-error"></span>
                    </div>

                    <div class="glass-card mb-4" style="background: rgba(255, 255, 255, 0.45); padding: 1.25rem;">
                        <h4 class="h6 mb-2"><i class="bi bi-shield-check text-gradient me-2"></i>Quy định bảo mật & xử lý tài liệu</h4>
                        <ul class="text-muted-custom text-sm ps-3 mb-0" style="font-size: 0.875rem; line-height: 1.5rem;">
                            <li>Các tệp thi hành (như exe, msi, bat, sh) sẽ bị từ chối hoàn toàn vì lý do bảo mật.</li>
                            <li>Tên tài liệu không được trùng lặp trong phạm vi cùng một khóa học.</li>
                            <li>Sau khi tải lên, tài liệu sẽ tự động được đưa vào hàng đợi để trích xuất văn bản và phân mảnh sinh vector nhúng.</li>
                        </ul>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-premium flex-grow-1" id="submitBtn">
                            <i class="bi bi-upload"></i>
                            Tải lên
                        </button>
                        <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn-secondary-custom">
                            <i class="bi bi-x-circle"></i>
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function() {
            const dragArea = $('#dragArea');
            const fileInput = $('#fileInput, #File, input[type="file"]');
            const fileSelectedContainer = $('#fileSelectedContainer');
            const selectedFileName = $('#selectedFileName');
            const selectedFileSize = $('#selectedFileSize');
            const clearFileBtn = $('#clearFileBtn');
            const submitBtn = $('#submitBtn');

            // Open file selector on drag area click
            dragArea.on('click', function() {
                fileInput.trigger('click');
            });

            // Prevent browser defaults on drag events
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dragArea.on(eventName, function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                });
            });

            // Highlight drag area on hover
            ['dragenter', 'dragover'].forEach(eventName => {
                dragArea.on(eventName, function() {
                    dragArea.addClass('border-primary').css('background', 'rgba(139, 92, 246, 0.08)');
                });
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dragArea.on(eventName, function() {
                    dragArea.removeClass('border-primary').css('background', 'rgba(255, 253, 248, 0.4)');
                });
            });

            // Handle dropped files
            dragArea.on('drop', function(e) {
                const files = e.originalEvent.dataTransfer.files;
                if (files.length > 0) {
                    fileInput[0].files = files;
                    updateFileDetails();
                }
            });

            // Handle file selection change
            fileInput.on('change', function() {
                updateFileDetails();
            });

            // Clear selected file
            clearFileBtn.on('click', function(e) {
                e.stopPropagation();
                fileInput.val('');
                fileSelectedContainer.addClass('d-none');
                dragArea.removeClass('d-none');
            });

            function updateFileDetails() {
                const files = fileInput[0].files;
                if (files.length > 0) {
                    const file = files[0];
                    const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
                    
                    selectedFileName.text(file.name);
                    selectedFileSize.text(`(${sizeMB} MB)`);
                    
                    dragArea.addClass('d-none');
                    fileSelectedContainer.removeClass('d-none');
                }
            }
        });
    </script>
}
