@model RagChatBox.Presentation.Models.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    
    // Map role to Vietnamese readable string
    var roleName = Model.Role.ToLower() switch
    {
        "admin" => "Quản trị viên",
        "teacher" => "Giáo viên",
        "student" => "Học sinh/Sinh viên",
        _ => Model.Role
    };
    
    var roleBadgeClass = Model.Role.ToLower() switch
    {
        "admin" => "bg-danger",
        "teacher" => "bg-primary",
        _ => "bg-success"
    };
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Left Panel: User Profile Info -->
        <div class="col-lg-5 col-md-6">
            <div class="glass-panel h-100 d-flex flex-column justify-content-between">
                <div>
                    <div class="text-center mb-4">
                        <div class="icon-badge mx-auto mb-3">
                            <i class="bi bi-person-circle text-primary"></i>
                        </div>
                        <h2 class="h3 mb-1 fw-bold">@Model.FullName</h2>
                        <span class="badge @roleBadgeClass px-3 py-2 rounded-pill fs-7">@roleName</span>
                    </div>

                    <hr class="my-4 border-light opacity-50" />

                    <div class="space-y-3">
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light border-opacity-10">
                            <span class="text-muted-custom fw-semibold"><i class="bi bi-envelope me-2 text-primary"></i>Email / Username</span>
                            <span class="text-dark fw-medium">@Model.Username</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light border-opacity-10">
                            <span class="text-muted-custom fw-semibold"><i class="bi bi-calendar3 me-2 text-primary"></i>Ngày đăng ký</span>
                            <span class="text-dark fw-medium">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <p class="text-muted-custom small mb-0">Hệ thống RAG Chatbot &amp; Research Platform</p>
                </div>
            </div>
        </div>

        <!-- Right Panel: Change Password -->
        <div class="col-lg-7 col-md-6">
            <div class="glass-panel">
                <div class="mb-4">
                    <h3 class="h4 mb-1 fw-bold"><i class="bi bi-shield-lock me-2 text-primary"></i>Đổi mật khẩu</h3>
                    <p class="text-muted-custom small">Thay đổi mật khẩu tài khoản của bạn để bảo mật tốt hơn.</p>
                </div>

                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3 fs-7 rounded-3" role="alert"></div>

                    <div class="form-group-custom">
                        <label asp-for="OldPassword" class="form-label-custom">
                            <i class="bi bi-key me-2 text-muted"></i>Mật khẩu hiện tại
                        </label>
                        <input asp-for="OldPassword" class="form-control-custom" type="password" placeholder="Nhập mật khẩu hiện tại" autocomplete="current-password" />
                        <span asp-validation-for="OldPassword" class="validation-error"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="NewPassword" class="form-label-custom">
                            <i class="bi bi-lock me-2 text-muted"></i>Mật khẩu mới
                        </label>
                        <input asp-for="NewPassword" class="form-control-custom" type="password" placeholder="Mật khẩu mới từ 6 ký tự" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="validation-error"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="ConfirmNewPassword" class="form-label-custom">
                            <i class="bi bi-shield-check me-2 text-muted"></i>Xác nhận mật khẩu mới
                        </label>
                        <input asp-for="ConfirmNewPassword" class="form-control-custom" type="password" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmNewPassword" class="validation-error"></span>
                    </div>

                    <button type="submit" class="btn-premium w-100 py-3 mt-3">
                        <i class="bi bi-save me-2"></i>Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
