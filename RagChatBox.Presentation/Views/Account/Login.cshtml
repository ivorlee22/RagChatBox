@model RagChatBox.Presentation.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6 col-lg-5">
        <div class="glass-panel">
            <div class="text-center mb-4">
                <div class="icon-badge mx-auto mb-3"><i class="bi bi-box-arrow-in-right"></i></div>
                <h1 class="h3 mb-2">Chào mừng trở lại</h1>
                <p class="text-muted-custom">Đăng nhập vào hệ thống RAG Chatbot & Research</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="alert-custom-danger mb-3" role="alert"></div>

                <div class="form-group-custom">
                    <label asp-for="Username" class="form-label-custom"><i class="bi bi-person me-2"></i>Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control-custom" placeholder="Nhập tên đăng nhập" autocomplete="username" />
                    <span asp-validation-for="Username" class="validation-error"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Password" class="form-label-custom"><i class="bi bi-lock me-2"></i>Mật khẩu</label>
                    <input asp-for="Password" class="form-control-custom" type="password" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="validation-error"></span>
                </div>

                <button type="submit" class="btn-premium w-100 py-3 mt-2">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Đăng nhập
                </button>
            </form>


        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
