@using RagChatBox.DAL.Entities
@{
    var course = ViewBag.Course as Course;
    var sessions = ViewBag.Sessions as List<ChatSession> ?? new();
    var activeSession = ViewBag.ActiveSession as ChatSession;
    var messages = ViewBag.Messages as List<Message> ?? new();
    ViewData["Title"] = $"Hỏi đáp AI - {course?.Name}";
}

<div class="chat-wrapper" style="height: calc(100vh - 180px); min-height: 550px; display: flex; gap: 20px; margin-top: 10px;">
    
    @* ── SIDEBAR: CHAT SESSIONS ────────────────────────────────────────────────── *@
    <div class="glass-panel d-flex flex-column" style="width: 280px; flex-shrink: 0; padding: 15px; border-radius: 16px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="m-0 fw-bold text-dark"><i class="bi bi-chat-left-text me-2 text-primary"></i>Hội thoại</h5>
            <form asp-action="CreateSession" method="post" class="m-0 p-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@course?.Id" />
                <button type="submit" class="btn btn-premium btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" title="Tạo cuộc hội thoại mới">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </form>
        </div>

        <div class="session-list overflow-auto flex-grow-1" style="margin-right: -5px; padding-right: 5px;">
            @if (!sessions.Any())
            {
                <div class="text-center text-muted-custom py-4 small">
                    Chưa có cuộc hội thoại nào.
                </div>
            }
            else
            {
                @foreach (var s in sessions)
                {
                    var isActive = activeSession != null && s.Id == activeSession.Id;
                    <div class="session-item position-relative mb-2 rounded-3 @(isActive ? "session-active" : "")" style="transition: all 0.2s ease;">
                        <a href="?courseId=@course?.Id&sessionId=@s.Id" class="d-block py-2.5 px-3 text-decoration-none text-dark pe-5 text-truncate" style="font-size: 0.9rem;">
                            <i class="bi bi-chat-dots me-2 text-muted"></i>
                            @s.Title
                        </a>
                        <form asp-action="DeleteSession" method="post" class="position-absolute end-0 top-50 translate-middle-y me-2 m-0 p-0" onsubmit="return confirm('Xóa cuộc hội thoại này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@s.Id" />
                            <input type="hidden" name="courseId" value="@course?.Id" />
                            <button type="submit" class="btn btn-link text-danger p-1 border-0 btn-delete-session" style="opacity: 0.5; transition: opacity 0.2s;" title="Xóa">
                                <i class="bi bi-trash fs-7"></i>
                            </button>
                        </form>
                    </div>
                }
            }
        </div>

        <div class="mt-3 pt-3 border-top">
            <a asp-controller="Document" asp-action="Index" asp-route-courseId="@course?.Id" class="btn btn-outline-secondary w-100 btn-sm rounded-pill py-2">
                <i class="bi bi-arrow-left me-1"></i> Quay lại tài liệu
            </a>
        </div>
    </div>

    @* ── MAIN PANEL: CHAT INTERACTIVE SPACE ─────────────────────────────────────── *@
    <div class="glass-panel flex-grow-1 d-flex flex-column" style="border-radius: 16px; overflow: hidden; position: relative; padding: 0;">
        @if (activeSession == null)
        {
            @* ── WELCOME & CREATE FIRST SESSION DASHBOARD ───────────────────────────── *@
            <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 text-center p-4">
                <div class="chat-welcome-pulse mb-4">
                    <i class="bi bi-stars text-gradient" style="font-size: 4rem;"></i>
                </div>
                <h3 class="fw-bold mb-2">Trợ lý ảo RAG Chatbot</h3>
                <p class="text-muted-custom max-width-md mb-4" style="max-width: 500px;">
                    Chào mừng bạn đến với hệ thống hỏi đáp thông minh dựa trên tài liệu của lớp <strong>@course?.Name</strong>. 
                    Mọi câu trả lời của AI đều được trích dẫn trực tiếp từ tài liệu học tập của bạn.
                </p>

                <form asp-action="CreateSession" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@course?.Id" />
                    <button type="submit" class="btn btn-premium px-4 py-2.5 rounded-pill shadow-sm">
                        <i class="bi bi-chat-plus-fill me-2"></i> Bắt đầu hội thoại ngay
                    </button>
                </form>

                <div class="w-100" style="max-width: 600px;">
                    <p class="text-muted-custom small mb-3">Bạn có thể hỏi những gì?</p>
                    <div class="row g-2">
                        <div class="col-sm-6">
                            <button class="btn btn-light border w-100 text-start py-2.5 px-3 rounded-3 text-sm quick-question-btn">
                                <i class="bi bi-search text-primary me-2"></i>Tóm tắt tài liệu môn học này
                            </button>
                        </div>
                        <div class="col-sm-6">
                            <button class="btn btn-light border w-100 text-start py-2.5 px-3 rounded-3 text-sm quick-question-btn">
                                <i class="bi bi-bookmark text-success me-2"></i>Liệt kê các khái niệm cốt lõi
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* ── ACTIVE CHAT DISPLAY ────────────────────────────────────────────────── *@
            <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom bg-white bg-opacity-50">
                <div>
                    <h6 class="m-0 fw-bold text-dark text-truncate" style="max-width: 450px;">
                        <i class="bi bi-chat-right-dots me-2 text-primary"></i>
                        @activeSession.Title
                    </h6>
                    <span class="text-muted-custom" style="font-size: 0.8rem;">
                        Đang kết nối: @course?.Name
                    </span>
                </div>
                <div class="d-flex gap-2">
                    <span class="badge bg-light text-secondary border rounded-pill d-inline-flex align-items-center gap-1 py-1.5 px-2.5">
                        <i class="bi bi-lightning-charge"></i> Gemini API (RAG)
                    </span>
                </div>
            </div>

            @* ── MESSAGES VIEWPORT ──────────────────────────────────────────────────── *@
            <div id="chatMessagesViewport" class="flex-grow-1 overflow-auto px-4 py-4" style="background-color: rgba(248,249,250,0.45);">
                @if (!messages.Any())
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted-custom py-5">
                        <i class="bi bi-chat-left-dots fs-1 mb-2 text-muted" style="opacity: 0.5;"></i>
                        <p class="m-0">Chưa có câu hỏi nào. Hãy gửi câu hỏi đầu tiên!</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in messages)
                    {
                        var isUser = msg.Role == "user";
                        <div class="d-flex mb-4 message-row @(isUser ? "justify-content-end" : "justify-content-start")">
                            
                            @if (!isUser)
                            {
                                <div class="ai-avatar me-2.5 d-flex align-items-center justify-content-center rounded-circle text-white shadow-sm" style="width: 36px; height: 36px; flex-shrink: 0;">
                                    <i class="bi bi-stars" style="font-size: 0.95rem;"></i>
                                </div>
                            }

                            <div class="message-bubble-container" style="max-width: 75%;">
                                <div class="message-bubble p-3 rounded-4 shadow-sm @(isUser ? "bg-user-gradient text-white" : "bg-assistant-glass border")" style="font-size: 0.95rem; white-space: pre-wrap; line-height: 1.5;">@Html.Raw(msg.Content)</div>

                                <div class="d-flex align-items-center gap-2 mt-1 px-1 @(isUser ? "justify-content-end" : "justify-content-start")" style="font-size: 0.75rem; color: #8c8c8c;">
                                    <span>@msg.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                                    @if (!isUser && msg.TokensUsed > 0)
                                    {
                                        <span>•</span>
                                        <span>@msg.TokensUsed tokens</span>
                                    }
                                </div>

                                @if (!isUser && msg.RetrievalLogs.Any())
                                {
                                    <div class="mt-2 text-start">
                                        <button class="btn btn-link btn-sm p-0 d-inline-flex align-items-center gap-1 text-decoration-none citation-toggle-btn">
                                            <i class="bi bi-journal-bookmark-fill"></i>
                                            Nguồn tài liệu tham khảo (@msg.RetrievalLogs.Count)
                                            <i class="bi bi-chevron-down citation-chevron"></i>
                                        </button>
                                        <div class="citation-details-container d-none mt-2">
                                            @foreach (var log in msg.RetrievalLogs.OrderBy(l => l.Rank))
                                            {
                                                <div class="p-3 rounded-3 citation-card mb-2" style="font-size: 0.8rem;">
                                                    <div class="d-flex justify-content-between align-items-center fw-semibold mb-1" style="color: #4b5563;">
                                                        <span class="text-truncate" style="max-width: 80%;"><i class="bi bi-file-earmark-text me-1 text-primary"></i>@log.Chunk.Document.FileName</span>
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem;">
                                                            @((log.SimilarityScore * 100).ToString("F1"))% khớp
                                                        </span>
                                                    </div>
                                                    <div class="text-muted-custom" style="font-size: 0.78rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" title="@log.Chunk.Content">
                                                        @log.Chunk.Content
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                
                @* ── TYPING SKELETON / LOADING LOADER ────────────────────────────────────── *@
                <div id="aiTypingIndicator" class="d-none mb-4 justify-content-start message-row">
                    <div class="ai-avatar me-2.5 d-flex align-items-center justify-content-center rounded-circle text-white shadow-sm" style="width: 36px; height: 36px; flex-shrink: 0;">
                        <i class="bi bi-stars" style="font-size: 0.95rem;"></i>
                    </div>
                    <div class="message-bubble-container" style="max-width: 75%;">
                        <div class="message-bubble bg-assistant-glass border p-3 rounded-4 shadow-sm">
                            <div class="typing-dots d-flex gap-1.5 align-items-center py-1">
                                <span class="dot rounded-circle" style="width: 7px; height: 7px; animation: bounce 1.4s infinite ease-in-out both;"></span>
                                <span class="dot rounded-circle" style="width: 7px; height: 7px; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.2s;"></span>
                                <span class="dot rounded-circle" style="width: 7px; height: 7px; animation: bounce 1.4s infinite ease-in-out both; animation-delay: 0.4s;"></span>
                            </div>
                        </div>
                        <span class="text-muted-custom small mt-1 px-1 d-block" style="font-size: 0.75rem;">AI đang suy nghĩ...</span>
                    </div>
                </div>
            </div>

            @* ── BOTTOM INPUT ZONE ──────────────────────────────────────────────────── *@
            <div class="px-4 py-3 border-top bg-white bg-opacity-70">
                <form id="chatForm" class="m-0 p-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="sessionIdInput" name="sessionId" value="@activeSession.Id" />
                    <div class="input-group gap-2 align-items-center chat-input-container shadow-sm py-1.5">
                        <textarea id="chatInput" name="content" class="form-control border-0 bg-transparent py-2 resize-none" rows="1" placeholder="Hỏi tôi bất cứ điều gì liên quan đến tài liệu môn học..." style="box-shadow: none; font-size: 0.95rem; max-height: 100px; resize: none; overflow-y: auto; outline: none;"></textarea>
                        <button type="submit" id="sendBtn" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0; border: none;" title="Gửi">
                            <i class="bi bi-send-fill text-white fs-6" style="margin-left: 2px;"></i>
                        </button>
                    </div>
                    <div class="text-muted-custom text-center mt-2" style="font-size: 0.75rem;">
                        Câu trả lời chỉ giới hạn trong phạm vi tài liệu đã tải lên khóa học.
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@* ── STYLES OVERRIDES FOR PREMIUM UI ─────────────────────────────────────────── *@
<style>
    /* Slide in animation for messages */
    .message-row {
        animation: fadeInUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* AI Avatar */
    .ai-avatar {
        background: var(--primary-gradient) !important;
        box-shadow: 0 4px 10px rgba(255, 138, 138, 0.2);
        transition: transform 0.2s ease;
    }
    .ai-avatar:hover {
        transform: rotate(15deg) scale(1.05);
    }

    /* Chat Bubbles */
    .message-bubble {
        border-radius: 18px !important;
        font-family: var(--font-primary);
        box-shadow: 0 3px 12px rgba(51, 65, 85, 0.03) !important;
    }
    
    .bg-user-gradient {
        background: var(--primary-gradient) !important;
        color: #FFFFFF !important;
        border-bottom-right-radius: 4px !important;
        box-shadow: 0 4px 15px rgba(255, 138, 138, 0.15) !important;
    }
    
    .bg-assistant-glass {
        background: #FFFFFF !important;
        border: 1px solid var(--border-light) !important;
        border-bottom-left-radius: 4px !important;
        color: var(--text-primary) !important;
    }

    /* Session Sidebar */
    .session-item {
        margin-bottom: 6px;
        border-radius: 12px !important;
        overflow: hidden;
    }
    .session-item a {
        color: var(--text-primary) !important;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .session-item:hover {
        background-color: rgba(255, 138, 138, 0.05) !important;
    }
    .session-active {
        background-color: rgba(255, 138, 138, 0.09) !important;
        border-left: 4px solid var(--color-primary);
        border-radius: 0 12px 12px 0 !important;
    }
    .session-active a {
        color: var(--color-primary) !important;
        font-weight: 600 !important;
    }
    .session-item:hover .btn-delete-session {
        opacity: 1 !important;
    }
    
    /* Input Form Area */
    .chat-input-container {
        background: #FFFFFF;
        border: 1px solid var(--border-light) !important;
        border-radius: 28px !important;
        transition: all 0.25s ease;
        padding-left: 15px !important;
        padding-right: 8px !important;
    }
    .chat-input-container:focus-within {
        border-color: var(--color-primary) !important;
        box-shadow: 0 0 0 3px rgba(255, 138, 138, 0.15), 0 4px 20px rgba(51, 65, 85, 0.05) !important;
    }
    
    #sendBtn {
        background: var(--primary-gradient) !important;
        box-shadow: 0 4px 10px rgba(255, 138, 138, 0.25) !important;
        transition: all 0.2s ease !important;
    }
    #sendBtn:hover:not(:disabled) {
        transform: scale(1.08);
        box-shadow: 0 6px 15px rgba(255, 138, 138, 0.35) !important;
    }
    #sendBtn:active:not(:disabled) {
        transform: scale(0.95);
    }
    
    /* Welcome cards */
    .quick-question-btn {
        background: #FFFFFF !important;
        border: 1px solid var(--border-light) !important;
        font-weight: 500;
        color: var(--text-primary) !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        box-shadow: 0 2px 8px rgba(51, 65, 85, 0.02) !important;
    }
    .quick-question-btn:hover {
        transform: translateY(-2px);
        border-color: var(--color-primary) !important;
        box-shadow: 0 6px 16px rgba(255, 138, 138, 0.08) !important;
        background: rgba(255, 138, 138, 0.02) !important;
    }

    /* Citation Toggle & Details */
    .citation-toggle-btn {
        color: var(--color-primary) !important;
        font-weight: 600;
        transition: opacity 0.2s;
        outline: none;
        border: none;
        background: none;
    }
    .citation-toggle-btn:hover {
        opacity: 0.8;
    }
    
    .citation-card {
        border-left: 3px solid var(--color-primary) !important;
        background: #FFFFFF;
        border: 1px solid var(--border-light);
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(51, 65, 85, 0.02);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .citation-card:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(255, 138, 138, 0.06);
    }
    
    .chat-welcome-pulse i {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: pulse-glow 2.5s infinite alternate;
    }
    .fs-7 {
        font-size: 0.8rem;
    }
    
    /* Typing Dots Animation */
    .typing-dots .dot {
        background-color: var(--color-primary) !important;
    }
    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1.0); }
    }
    @@keyframes pulse-glow {
        from { filter: drop-shadow(0 0 5px rgba(255, 138, 138, 0.2)); }
        to { filter: drop-shadow(0 0 15px rgba(255, 138, 138, 0.6)); }
    }
    
    /* Custom Scrollbar */
    .session-list::-webkit-scrollbar,
    #chatMessagesViewport::-webkit-scrollbar {
        width: 6px;
    }
    .session-list::-webkit-scrollbar-thumb,
    #chatMessagesViewport::-webkit-scrollbar-thumb {
        background-color: rgba(255, 138, 138, 0.2);
        border-radius: 4px;
    }
    .session-list::-webkit-scrollbar-thumb:hover,
    #chatMessagesViewport::-webkit-scrollbar-thumb:hover {
        background-color: rgba(255, 138, 138, 0.4);
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            var $viewport = $('#chatMessagesViewport');

            // Scroll to bottom helper
            function scrollToBottom(animate) {
                if ($viewport.length) {
                    var scrollHeight = $viewport[0].scrollHeight;
                    if (animate) {
                        $viewport.animate({ scrollTop: scrollHeight }, 300);
                    } else {
                        $viewport.scrollTop(scrollHeight);
                    }
                }
            }

            // Initial Scroll to bottom
            scrollToBottom(false);

            // Handle Textarea Enter Key
            $('#chatInput').on('keydown', function(e) {
                if (e.which === 13 && !e.shiftKey) {
                    e.preventDefault();
                    $('#chatForm').submit();
                }
            });

            // Handle Quick Questions click
            $('.quick-question-btn').on('click', function() {
                var text = $(this).text().trim();
                var $creationForm = $(this).closest('.glass-panel').find('form');
                if ($creationForm.length) {
                    var $titleInput = $('<input>').attr({
                        type: 'hidden',
                        name: 'title',
                        value: text
                    });
                    $creationForm.append($titleInput);
                    $creationForm.submit();
                }
            });

            // Toggle Citations collapse
            $(document).on('click', '.citation-toggle-btn', function(e) {
                e.preventDefault();
                var $btn = $(this);
                var $container = $btn.siblings('.citation-details-container');
                var $chevron = $btn.find('.citation-chevron');

                if ($container.hasClass('d-none')) {
                    $container.removeClass('d-none');
                    $chevron.removeClass('bi-chevron-down').addClass('bi-chevron-up');
                    scrollToBottom(true);
                } else {
                    $container.addClass('d-none');
                    $chevron.removeClass('bi-chevron-up').addClass('bi-chevron-down');
                }
            });

            // AJAX Chat Submission
            $('#chatForm').on('submit', function (e) {
                e.preventDefault();
                var $input = $('#chatInput');
                var content = $input.val().trim();
                var sessionId = $('#sessionIdInput').val();

                if (!content) return;

                // 1. Clear input & disable button
                $input.val('').trigger('input');
                $('#sendBtn').prop('disabled', true);

                // 2. Append User Message to viewport
                var userTime = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                var userHtml = `
                    <div class="d-flex mb-4 justify-content-end message-row">
                        <div class="message-bubble-container" style="max-width: 75%;">
                            <div class="message-bubble bg-user-gradient text-white p-3 rounded-4 shadow-sm" style="font-size: 0.95rem; white-space: pre-wrap; line-height: 1.5;">${escapeHtml(content)}</div>
                            <div class="d-flex align-items-center justify-content-end mt-1 px-1" style="font-size: 0.75rem; color: #8c8c8c;">
                                <span>${userTime}</span>
                            </div>
                        </div>
                    </div>`;
                
                // Remove empty state message if exists
                $viewport.find('.h-100').remove();
                
                $('#aiTypingIndicator').before(userHtml);
                
                // Show Typing loader
                $('#aiTypingIndicator').removeClass('d-none').addClass('d-flex');
                scrollToBottom(true);

                // 3. Send Request
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Chat/SendMessage',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        sessionId: sessionId,
                        content: content
                    },
                    success: function (res) {
                        // Hide Typing loader
                        $('#aiTypingIndicator').removeClass('d-flex').addClass('d-none');
                        $('#sendBtn').prop('disabled', false);

                        if (res.success) {
                            // Append AI Response
                            var citationsHtml = '';
                            if (res.citations && res.citations.length > 0) {
                                var citationsList = '';
                                res.citations.forEach(function (c) {
                                    citationsList += `
                                        <div class="p-3 rounded-3 citation-card mb-2" style="font-size: 0.8rem;">
                                            <div class="d-flex justify-content-between align-items-center fw-semibold mb-1" style="color: #4b5563;">
                                                <span class="text-truncate" style="max-width: 80%;"><i class="bi bi-file-earmark-text me-1 text-primary"></i>${c.docName}</span>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem;">
                                                    ${(c.similarity * 100).toFixed(1)}% khớp
                                                </span>
                                            </div>
                                            <div class="text-muted-custom" style="font-size: 0.78rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;" title="${escapeHtml(c.snippet)}">
                                                ${escapeHtml(c.snippet)}
                                            </div>
                                        </div>`;
                                });

                                citationsHtml = `
                                    <div class="mt-2 text-start">
                                        <button class="btn btn-link btn-sm p-0 d-inline-flex align-items-center gap-1 text-decoration-none citation-toggle-btn">
                                            <i class="bi bi-journal-bookmark-fill"></i>
                                            Nguồn tài liệu tham khảo (${res.citations.length})
                                            <i class="bi bi-chevron-down citation-chevron"></i>
                                        </button>
                                        <div class="citation-details-container d-none mt-2">
                                            ${citationsList}
                                        </div>
                                    </div>`;
                            }

                            var tokenMeta = res.tokens > 0 ? `• <span>${res.tokens} tokens</span>` : '';

                            var aiHtml = `
                                <div class="d-flex mb-4 justify-content-start message-row">
                                    <div class="ai-avatar me-2.5 d-flex align-items-center justify-content-center rounded-circle text-white shadow-sm" style="width: 36px; height: 36px; flex-shrink: 0;">
                                        <i class="bi bi-stars" style="font-size: 0.95rem;"></i>
                                    </div>
                                    <div class="message-bubble-container" style="max-width: 75%;">
                                        <div class="message-bubble bg-assistant-glass border p-3 rounded-4 shadow-sm" style="font-size: 0.95rem; white-space: pre-wrap; line-height: 1.5;">${res.content}</div>
                                        <div class="d-flex align-items-center gap-2 mt-1 px-1 justify-content-start" style="font-size: 0.75rem; color: #8c8c8c;">
                                            <span>${res.createdAt}</span>
                                            ${tokenMeta}
                                        </div>
                                        ${citationsHtml}
                                    </div>
                                </div>`;

                            $('#aiTypingIndicator').before(aiHtml);
                            scrollToBottom(true);
                        } else {
                            // Show error message as bot bubble
                            var errHtml = `
                                <div class="d-flex mb-4 justify-content-start message-row">
                                    <div class="ai-avatar me-2.5 d-flex align-items-center justify-content-center rounded-circle bg-danger text-white shadow-sm" style="width: 36px; height: 36px; flex-shrink: 0;">
                                        <i class="bi bi-exclamation-triangle" style="font-size: 0.95rem;"></i>
                                    </div>
                                    <div class="message-bubble-container" style="max-width: 75%;">
                                        <div class="message-bubble bg-white border p-3 rounded-4 shadow-sm border-danger text-danger" style="font-size: 0.95rem;">${res.message || "Lỗi xử lý phản hồi từ AI."}</div>
                                    </div>
                                </div>`;
                            $('#aiTypingIndicator').before(errHtml);
                            scrollToBottom(true);
                        }
                    },
                    error: function () {
                        $('#aiTypingIndicator').removeClass('d-flex').addClass('d-none');
                        $('#sendBtn').prop('disabled', false);
                        
                        var errHtml = `
                            <div class="d-flex mb-4 justify-content-start message-row">
                                <div class="ai-avatar me-2.5 d-flex align-items-center justify-content-center rounded-circle bg-danger text-white shadow-sm" style="width: 36px; height: 36px; flex-shrink: 0;">
                                    <i class="bi bi-exclamation-triangle" style="font-size: 0.95rem;"></i>
                                </div>
                                <div class="message-bubble-container" style="max-width: 75%;">
                                    <div class="message-bubble bg-white border p-3 rounded-4 shadow-sm border-danger text-danger" style="font-size: 0.95rem;">Lỗi kết nối mạng hoặc phiên làm việc hết hạn. Vui lòng tải lại trang.</div>
                                </div>
                            </div>`;
                        $('#aiTypingIndicator').before(errHtml);
                        scrollToBottom(true);
                    }
                });
            });

            // HTML Escaper
            function escapeHtml(text) {
                if (!text) return '';
                return text
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }
        });
    </script>
}
