@model IEnumerable<RagChatBox.DAL.Entities.Course>
@{
    ViewData["Title"] = "Tìm lớp học";
    string keyword = ViewBag.Keyword ?? "";
}

<div class="page-container m-0 p-0">
    <div class="mb-4">
        <h1 class="h2 mb-1"><i class="bi bi-search text-gradient me-2"></i>Tìm lớp học</h1>
        <p class="text-muted-custom">Tìm kiếm lớp học của giáo viên và đăng ký tham gia.</p>
    </div>

    @* Search bar *@
    <form asp-action="Search" method="get" class="mb-4">
        <div class="d-flex gap-3">
            <input type="text" name="keyword" value="@keyword"
                   class="form-control-custom flex-grow-1"
                   placeholder="Nhập tên lớp, mô tả hoặc tên giáo viên..." />
            <button type="submit" class="btn-premium px-4">
                <i class="bi bi-search"></i>
                Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(keyword))
            {
                <a asp-action="Search" class="btn-secondary-custom px-3"><i class="bi bi-x-circle"></i>Xóa</a>
            }
        </div>
    </form>

    @if (!string.IsNullOrEmpty(keyword))
    {
        <p class="text-muted-custom mb-3">
            Kết quả tìm kiếm cho <strong class="text-dark">"@keyword"</strong>: @Model.Count() lớp học
        </p>
    }

    @if (!Model.Any())
    {
        <div class="glass-panel text-center py-5">
            <div class="icon-badge mx-auto mb-3"><i class="bi bi-search"></i></div>
            <h3 class="h5">Không tìm thấy lớp học nào</h3>
            <p class="text-muted-custom">
                @(string.IsNullOrEmpty(keyword)
                    ? "Hiện tại chưa có lớp học nào được công khai."
                    : "Thử tìm với từ khóa khác hoặc liên hệ giáo viên để được mời vào lớp.")
            </p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="glass-card course-card d-flex flex-column justify-content-between">
                        <div>
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="h5 mb-0 text-truncate" style="max-width:80%">@item.Name</h3>
                                @if (!string.IsNullOrEmpty(item.CoursePassword))
                                {
                                    <span class="text-warning small" title="Cần mật khẩu để tham gia">
                                        [Mật khẩu]
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success small" title="Mở, không cần mật khẩu">
                                        [Tự do]
                                    </span>
                                }
                            </div>
                            <p class="text-muted-custom small mb-1">
                                <i class="bi bi-person-video3 me-1"></i>Giáo viên: @(item.CreatedByUser?.Name ?? "Giáo viên")
                            </p>
                            <p class="text-muted-custom text-sm mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                @(string.IsNullOrWhiteSpace(item.Description) ? "Không có mô tả." : item.Description)
                            </p>
                            <p class="text-muted-custom small">
                                <i class="bi bi-files me-1"></i>@item.Documents.Count tài liệu
                            </p>
                        </div>
                        <div class="mt-3">
                            <a asp-action="Enroll" asp-route-id="@item.Id" class="btn-premium py-2 w-100" style="box-shadow:none;text-align:center">
                                <i class="bi bi-door-open"></i>
                                Tham gia lớp
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn-secondary-custom">
            <i class="bi bi-arrow-left-circle"></i>Quay lại
        </a>
    </div>
</div>
