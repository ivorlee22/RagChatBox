@model RagChatBox.Presentation.Models.EnrollViewModel
@{
    ViewData["Title"] = "Tham gia lớp học";
}

<div class="page-container m-0 p-0">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="glass-panel">
                <div class="text-center mb-4">
                    <div class="mb-2">
                        @if (Model.RequiresPassword)
                        {
                            <span class="text-warning fw-semibold">[Yêu cầu mật khẩu]</span>
                        }
                        else
                        {
                            <span class="text-success fw-semibold">[Lớp công khai]</span>
                        }
                    </div>
                    <h2 class="h3 mb-1"><i class="bi bi-door-open text-gradient me-2"></i>Tham gia lớp học</h2>
                    <p class="text-dark fw-semibold">@Model.CourseName</p>
                    @if (!string.IsNullOrEmpty(Model.TeacherName))
                    {
                        <p class="text-muted-custom small">
                            <i class="bi bi-person-video3 me-1"></i>Giáo viên: @Model.TeacherName
                        </p>
                    }
                </div>

                <form asp-action="Enroll" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="CourseId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert-custom-danger mb-3" role="alert"></div>

                    @if (Model.RequiresPassword)
                    {
                        <div class="form-group-custom">
                            <label asp-for="Password" class="form-label-custom"><i class="bi bi-shield-lock me-2"></i>Mật khẩu lớp</label>
                            <div class="input-group-custom">
                                <input asp-for="Password" class="form-control-custom"
                                       type="password" placeholder="Nhập mật khẩu lớp học"
                                       autocomplete="off" autofocus />
                                <button type="button" class="btn-icon-toggle border-0" id="toggleEnrollPassword" style="background:none;">
                                    <span id="enrollPasswordText" class="text-muted small">Hiện</span>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="validation-error"></span>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success text-center py-2 mb-3" role="alert">
                            <p class="mb-0" style="font-size:0.95rem;"><i class="bi bi-unlock me-1"></i>Lớp học này mở, không cần mật khẩu.</p>
                        </div>
                    }

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn-premium flex-grow-1">
                            <i class="bi bi-check2-circle"></i>
                            Xác nhận tham gia
                        </button>
                        <a asp-action="Search" class="btn-secondary-custom"><i class="bi bi-x-circle"></i>Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('toggleEnrollPassword')?.addEventListener('click', function () {
            const input = document.getElementById('Password');
            const textSpan = document.getElementById('enrollPasswordText');
            if (input.type === 'password') {
                input.type = 'text';
                textSpan.textContent = 'Ẩn';
            } else {
                input.type = 'password';
                textSpan.textContent = 'Hiện';
            }
        });
    </script>
}
