@model IEnumerable<RagChatBox.DAL.Entities.CourseEnrollment>
@{
    ViewData["Title"] = "Danh sách học sinh";
    var course = ViewBag.Course as RagChatBox.DAL.Entities.Course;
}

<div class="page-container m-0 p-0">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h2 mb-1"><i class="bi bi-people-fill text-gradient me-2"></i>Danh sách học sinh</h1>
            <p class="text-muted-custom mb-0">Lớp: <span class="text-dark fw-semibold">@course?.Name</span></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Invite" asp-route-id="@course?.Id" class="btn-premium">
                <i class="bi bi-person-plus"></i>
                Mời học sinh
            </a>
            <a asp-action="Index" class="btn-secondary-custom">
                <i class="bi bi-arrow-left-circle"></i>Quay lại
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-panel text-center py-5">
            <div class="icon-badge mx-auto mb-3"><i class="bi bi-person-plus"></i></div>
            <h3 class="h5">Chưa có học sinh nào</h3>
            <p class="text-muted-custom mb-4">Mời học sinh hoặc đặt lớp hiển thị để học sinh tự tham gia.</p>
            <a asp-action="Invite" asp-route-id="@course?.Id" class="btn-premium">
                <i class="bi bi-person-plus"></i>
                Mời học sinh ngay
            </a>
        </div>
    }
    else
    {
        <div class="glass-panel p-0 overflow-hidden">
            <table class="table table-custom table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th><i class="bi bi-person-badge me-2"></i>Họ tên</th>
                        <th><i class="bi bi-at me-2"></i>Username</th>
                        <th><i class="bi bi-calendar-check me-2"></i>Ngày tham gia</th>
                        <th class="text-end px-4"><i class="bi bi-sliders me-2"></i>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int idx = 1; }
                    @foreach (var enrollment in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted-custom">@idx</td>
                            <td class="fw-semibold">@enrollment.User.Name</td>
                            <td class="text-muted-custom">@enrollment.User.Username</td>
                            <td class="text-muted-custom">@enrollment.EnrolledAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end px-4">
                                <form asp-action="RemoveStudent" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa học sinh @enrollment.User.Name khỏi lớp?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@course?.Id" />
                                    <input type="hidden" name="userId" value="@enrollment.UserId" />
                                    <button type="submit" class="btn-danger-custom py-1 px-3 fs-7">
                                        <i class="bi bi-person-dash"></i>
                                        Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                        idx++;
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted-custom small mt-2">Tổng: @Model.Count() học sinh</p>
    }
</div>
